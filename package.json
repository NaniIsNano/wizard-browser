{
  "name": "wizard-browser",
  "version": "1.5.0",
  "description": "Libre, privacy-focused browser powered by Wizard Search",
  "author": {
    "name": "NaniIsNano",
    "email": "naniis@nano.dev"
  },
  "license": "GPL-3.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis --linux AppImage",
    "build:win": "electron-builder --win nsis",
    "build:linux": "electron-builder --linux AppImage deb"
  },
  "contributors": [
    "MrBlight (https://github.com/MrBlight)"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/NaniIsNano/wizard-browser.git"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.wizard.browser",
    "productName": "Wizard Browser",
    "win": {
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "NaniIsNano",
        "repo": "wizard-browser",
        "releaseType": "release"
      }
    ],
    "files": [
      "main.js",
      "preload.js",
      "preload-search.js",
      "browser.html",
      "search.html",
      "tracker-list.json"
    ]
  }
}
