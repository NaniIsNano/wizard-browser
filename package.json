{
  "name": "wizard-browser",
  "version": "2.18.4",
  "description": "Libre, privacy-focused browser powered by Wizard Search",
  "author": {
    "name": "NaniIsNano",
    "email": "naniis@nano.dev"
  },
  "license": "SEE LICENSE IN LICENSE",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis --linux AppImage",
    "build:win": "electron-builder --win nsis",
    "build:linux": "electron-builder --linux AppImage deb"
  },
  "contributors": [
    "MrBlight (https://github.com/MrBlight)"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/NaniIsNano/wizard-browser.git"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.17.0",
    "adm-zip": "^0.5.17",
    "cross-fetch": "^4.1.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.wizard.browser",
    "productName": "Wizard Browser",
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/installer.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Wizard Browser",
      "menuCategory": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/installer.ico",
      "uninstallerIcon": "build/uninstaller.ico",
      "installerHeaderIcon": "build/installer.ico",
      "artifactName": "WizardBrowser-Setup-${version}.${ext}",
      "uninstallDisplayName": "Wizard Browser"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Network"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "NaniIsNano",
        "repo": "wizard-browser",
        "releaseType": "release"
      }
    ],
    "files": [
      "main.js",
      "config.js",
      "preload.js",
      "preload-search.js",
      "browser.html",
      "search.html",
      "settings.html",
      "extensions.html",
      "ubo-dashboard.html",
      "splash.html",
      "logo.png",
      "tracker-list.json",
      "THIRD-PARTY-LICENSES.txt",
      "backgrounds/**/*",
      "built-in-extensions/**/*"
    ],
    "extraResources": [
      {
        "from": "tor",
        "to": "tor",
        "filter": ["**/*"]
      }
    ]
  }
}
