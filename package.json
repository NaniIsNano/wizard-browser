{
  "name": "wizard-browser",
  "version": "2.19.0",
  "description": "Libre, privacy-focused browser powered by Wizard Search",
  "author": {
    "name": "NaniIsNano",
    "email": "naniis@nano.dev"
  },
  "license": "SEE LICENSE IN LICENSE",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win nsis --linux AppImage",
    "build:win": "electron-builder --win nsis",
    "build:linux": "electron-builder --linux AppImage deb",
    "build:flatpak": "electron-builder --linux flatpak",
    "build:mac": "electron-builder --mac dmg zip"
  },
  "contributors": [
    "MrBlight (https://github.com/MrBlight)"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/NaniIsNano/wizard-browser.git"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.17.0",
    "adm-zip": "^0.5.17",
    "cross-fetch": "^4.1.0",
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.wizard.browser",
    "productName": "Wizard Browser",
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/installer.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Wizard Browser",
      "menuCategory": false,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "installerIcon": "build/installer.ico",
      "uninstallerIcon": "build/uninstaller.ico",
      "installerHeaderIcon": "build/installer.ico",
      "artifactName": "WizardBrowser-Setup-${version}.${ext}",
      "uninstallDisplayName": "Wizard Browser"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "flatpak"
      ],
      "category": "Network",
      "icon": "logo.png",
      "executableName": "wizard-browser",
      "synopsis": "Libre, privacy-focused browser with built-in Wizard Search",
      "description": "Libre, privacy-focused browser powered by Wizard Search. Real uBlock Origin, bundled Tor, per-site padlock, no cookies, no telemetry."
    },
    "flatpak": {
      "runtime": "org.freedesktop.Platform",
      "runtimeVersion": "23.08",
      "sdk": "org.freedesktop.Sdk",
      "base": "org.electronjs.Electron2.BaseApp",
      "baseVersion": "23.08",
      "branch": "stable",
      "license": "LicenseRef-WPL-1.0",
      "finishArgs": [
        "--share=ipc",
        "--share=network",
        "--socket=x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--device=dri",
        "--filesystem=xdg-download:rw",
        "--talk-name=org.freedesktop.Notifications"
      ],
      "artifactName": "Wizard-Browser-${version}-${arch}.${ext}"
    },
    "mac": {
      "target": [
        { "target": "dmg",  "arch": ["x64"] },
        { "target": "zip",  "arch": ["x64"] }
      ],
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "artifactName": "WizardBrowser-${version}-${arch}.${ext}",
      "darkModeSupport": true,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null
    },
    "dmg": {
      "title": "Wizard Browser ${version}",
      "artifactName": "WizardBrowser-${version}-${arch}.${ext}",
      "writeUpdateInfo": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "NaniIsNano",
        "repo": "wizard-browser",
        "releaseType": "release"
      }
    ],
    "files": [
      "main.js",
      "config.js",
      "preload.js",
      "preload-search.js",
      "browser.html",
      "search.html",
      "settings.html",
      "extensions.html",
      "ubo-dashboard.html",
      "splash.html",
      "logo.png",
      "tracker-list.json",
      "THIRD-PARTY-LICENSES.txt",
      "backgrounds/**/*",
      "built-in-extensions/**/*"
    ],
    "extraResources": [
      {
        "from": "tor",
        "to": "tor",
        "filter": ["**/*"]
      }
    ]
  }
}
